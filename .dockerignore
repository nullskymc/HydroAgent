# 版本控制
.git
.gitignore

# 临时文件和缓存
__pycache__/
*.py[cod]
*$py.class
*.so
*.dylib
.Python
*.log
.pytest_cache/
.coverage
htmlcov/

# 虚拟环境
.env
.venv
env/
venv/
ENV/

# 前端依赖和构建产物
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/

# 测试文件
tests/
test_*.py

# 文档和其他非必要文件
docs/
README.md
LICENSE
test_report.txt
.DS_Store

# 本地运行态数据
.hydro_workspace/
logs/
irrigation_db.db
*.sqlite
*.sqlite3

# IDE相关
.idea/
.vscode/
*.sublime-*

# 镜像构建过程中会生成的文件
Dockerfile
.dockerignore
